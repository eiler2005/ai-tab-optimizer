{
  "manifest_version": 3,
  "name": "AI Tab Optimizer",
  "version": "0.2.0",
  "description": "Intelligent tab manager with AI analysis and Obsidian integration",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "alarms",
    "sessions",
    "sidePanel",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://[::1]/*"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/side-panel/index.html"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "AI Tab Optimizer"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "128x128.png"],
      "matches": ["<all_urls>"],
      "extension_pages": ["*"]
    }
  ],
  "minimum_chrome_version": "114"
}
